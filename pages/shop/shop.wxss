/* pages/shop/shop.wxss */
.shop-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFF3E0 50%, #FBE9E7 100%);
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 状态栏 */
.status-bar {
  background: linear-gradient(135deg, #5D4037, #795548);
  color: #FFF8E1;
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 6rpx 16rpx rgba(62, 39, 15, 0.3);
  margin-bottom: 20rpx;
}

.status-item {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
}

.status-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.status-value {
  font-size: 30rpx;
}

/* 商店标题 */
.shop-header {
  text-align: center;
  margin: 20rpx 0 30rpx;
}

.shop-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #5D4037;
  display: block;
}

.shop-subtitle {
  font-size: 24rpx;
  color: #8D6E63;
  margin-top: 8rpx;
  display: block;
}

/* 种子卡片 */
.seed-shop-list {
  margin: 20rpx 0;
}

.shop-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  animation: slideInUp 0.5s ease-out both;
  border-left: 8rpx solid #8BC34A;
}

@keyframes slideInUp {
  from { transform: translateY(30rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.shop-card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.shop-crop-emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
  filter: drop-shadow(0 4rpx 4rpx rgba(0, 0, 0, 0.15));
}

.shop-crop-info {
  display: flex;
  flex-direction: column;
}

.shop-crop-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.shop-crop-detail {
  font-size: 22rpx;
  color: #9E9E9E;
  margin-top: 4rpx;
}

.shop-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.shop-price {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.price-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6F00;
}

.btn-buy {
  background: linear-gradient(135deg, #FF9800, #F57C00);
  color: white;
  padding: 12rpx 36rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(245, 124, 0, 0.3);
  transition: all 0.2s;
}

.btn-buy:active {
  transform: scale(0.95);
}

.btn-buy.disabled {
  background: #BDBDBD;
  color: #9E9E9E;
  box-shadow: none;
}

/* 小贴士 */
.shop-tips {
  margin-top: 30rpx;
}

.tip-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border-left: 8rpx solid #FFC107;
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5D4037;
  display: block;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #757575;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1.6;
}
