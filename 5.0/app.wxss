/* app.wxss */
page {
  background-color: #E8F5E9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
}

/* 通用按钮样式 */
.btn {
  background-color: #4CAF50;
  color: white;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(76, 175, 80, 0.3);
  transition: all 0.2s;
  margin: 10rpx;
  display: inline-block;
}

.btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 4rpx rgba(76, 175, 80, 0.3);
}

.btn.disabled {
  background-color: #BDBDBD;
  color: #757575;
  box-shadow: none;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 状态栏 */
.status-bar {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

.status-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.status-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

/* 动画类 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideInUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(5deg); }
  75% { transform: rotate(-5deg); }
}

@keyframes coinFly {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-100rpx, -200rpx) scale(0); opacity: 0; }
}

@keyframes waterDrop {
  0% { transform: translateY(-100rpx) scale(0.5); opacity: 0; }
  50% { transform: translateY(0) scale(1); opacity: 1; }
  100% { transform: translateY(100rpx) scale(0.5); opacity: 0; }
}

@keyframes seedDrop {
  0% { transform: translateY(-200rpx) rotate(0deg); opacity: 0; }
  50% { transform: translateY(0) rotate(180deg); opacity: 1; }
  100% { transform: translateY(0) rotate(360deg); opacity: 1; }
}

@keyframes growUp {
  0% { transform: scale(0.1); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.5s ease-out;
}

.slide-in-up {
  animation: slideInUp 0.6s ease-out;
}

.bounce {
  animation: bounce 0.8s infinite;
}

.shake {
  animation: shake 0.5s infinite;
}

.coin-fly {
  animation: coinFly 1s ease-out forwards;
}

.water-drop {
  animation: waterDrop 1s ease-out;
}

.seed-drop {
  animation: seedDrop 0.8s ease-out;
}

.grow-up {
  animation: growUp 0.8s ease-out;
}
