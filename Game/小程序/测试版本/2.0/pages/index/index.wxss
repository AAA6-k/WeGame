/* pages/index/index.wxss */
.farm-container {
  min-height: 100vh;
  background: #E8F5E9;
  padding: 20rpx;
}

.status-bar {
  background: #795548;
  color: #FFF8E1;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 10rpx;
}

.status-item { display: flex; align-items: center; font-size: 26rpx; font-weight: bold; }
.status-icon { font-size: 36rpx; margin-right: 6rpx; }
.status-value { font-size: 26rpx; }

.level-bar {
  background: rgba(255,255,255,0.85);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 10rpx;
}

.level-info { display: flex; justify-content: space-between; margin-bottom: 6rpx; }
.level-text { font-size: 24rpx; font-weight: bold; color: #FF6F00; }
.exp-text { font-size: 22rpx; color: #757575; }

.exp-bar { width: 100%; height: 14rpx; background: #E0E0E0; border-radius: 7rpx; overflow: hidden; }
.exp-fill { height: 100%; background: #FFB300; border-radius: 7rpx; }

.farm-header { text-align: center; margin: 16rpx 0; }
.farm-title { font-size: 36rpx; font-weight: bold; color: #33691E; display: block; }
.farm-subtitle { font-size: 20rpx; color: #689F38; margin-top: 6rpx; display: block; }

.land-grid { display: flex; flex-wrap: wrap; padding: 6rpx; }

.land-cell {
  width: calc(25% - 18rpx);
  height: calc(25vw - 30rpx);
  margin: 0 9rpx 18rpx 9rpx;
  border-radius: 14rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.land-empty { background: #A1887F; border: 3rpx dashed #6D4C41; }
.land-mature { background: #8BC34A; border: 3rpx solid #FFD54F; }
.land-locked { 
  background: #BDBDBD; 
  border: 3rpx solid #9E9E9E; 
}

.land-locked .land-locked-overlay {
  width: 100%; 
  height: 100%; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  justify-content: center; 
  background: rgba(0,0,0,0.25);
}

.lock-icon { font-size: 40rpx; }
.lock-text { font-size: 20rpx; color: #424242; margin-top: 4rpx; font-weight: bold; }

.land-content {
  width: 100%; height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #8D6E63;
}

.land-empty-content { background: #A1887F; }
.land-empty-icon { font-size: 40rpx; }
.land-empty-text { font-size: 18rpx; color: #EFEBE9; margin-top: 2rpx; }

.crop-stage { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; height: 100%; }
.crop-emoji { font-size: 50rpx; }
.stage-label { font-size: 18rpx; color: #FFF8E1; margin-top: 2rpx; }
.ready-label { color: #FFD54F; font-weight: bold; font-size: 20rpx; }

.progress-bar {
  width: 70%; height: 6rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 3rpx;
  margin-top: 6rpx;
  overflow: hidden;
}
.progress-fill { height: 100%; background: #66BB6A; border-radius: 3rpx; }

.watered-badge {
  position: absolute;
  top: 2rpx; right: 2rpx;
  font-size: 16rpx;
  color: #29B6F6;
  background: rgba(255,255,255,0.8);
  border-radius: 6rpx;
  padding: 1rpx 6rpx;
  z-index: 5;
}

.plant-animation, .water-overlay, .harvest-animation, .coin-overlay {
  position: absolute; width: 100%; height: 100%;
  top: 0; left: 0;
  pointer-events: none;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-overlay {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.picker-dialog {
  width: 85%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
}

.picker-title { font-size: 36rpx; font-weight: bold; color: #33691E; text-align: center; margin-bottom: 8rpx; }
.picker-subtitle { font-size: 24rpx; color: #757575; text-align: center; margin-bottom: 20rpx; }
.seed-list { margin: 20rpx 0; }

.seed-option {
  display: flex; align-items: center;
  padding: 20rpx;
  border: 3rpx solid #E0E0E0;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.seed-option.selected { border-color: #4CAF50; background: #F1F8E9; }
.seed-emoji { font-size: 50rpx; margin-right: 16rpx; }
.seed-info { flex: 1; }
.seed-name { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.seed-detail { font-size: 22rpx; color: #757575; margin-top: 4rpx; }

.picker-actions { display: flex; justify-content: space-between; margin-top: 20rpx; }

.btn {
  flex: 1; padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin: 0 10rpx;
}

.btn-cancel { background: #EEEEEE; color: #757575; }
.btn-confirm { background: #4CAF50; color: white; }
.btn.disabled { background: #BDBDBD; color: #9E9E9E; }
