/* pages/kitchen/kitchen.wxss */

.kitchen-page {
  min-height: 100vh;
  background: #FFF3E0;
  padding-bottom: 40rpx;
}

/* 页签 */
.tabs {
  display: flex;
  background: #FF9800;
  padding: 10rpx 20rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  color: rgba(255,255,255,0.7);
  font-size: 30rpx;
  border-radius: 12rpx;
  margin: 0 6rpx;
}
.tab.active {
  color: #fff;
  background: rgba(255,255,255,0.25);
  font-weight: bold;
}

.tab-content {
  padding: 20rpx;
}

/* 烹饪 */
.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}
.recipe-card {
  width: calc(25% - 12rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.recipe-card:nth-child(4n) {
  margin-right: 0;
}
.recipe-card.selected {
  border: 4rpx solid #FF9800;
  background: #FFF8E1;
}
.recipe-card.locked {
  opacity: 0.5;
}
.recipe-emoji {
  font-size: 48rpx;
  margin-bottom: 6rpx;
}
.recipe-name {
  font-size: 22rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 4rpx;
}
.recipe-lv {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 配方详情 */
.recipe-detail {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.detail-emoji { font-size: 52rpx; margin-right: 16rpx; }
.detail-name { font-size: 34rpx; font-weight: bold; color: #333; flex: 1; }
.detail-lv { font-size: 24rpx; color: #FF9800; background: #FFF3E0; padding: 4rpx 16rpx; border-radius: 20rpx; }

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-label { color: #666; }
.info-val { font-weight: bold; }
.info-val.enough { color: #4CAF50; }
.info-val.lack { color: #F44336; }
.info-val.price { color: #FF9800; font-size: 32rpx; }

.cook-btn {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #FF9800, #F57C00);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  border: none;
}
.cook-btn::after { border: none; }

/* 库存 */
.inventory-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.inv-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.inv-item:last-child { border-bottom: none; }
.inv-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}
.inv-emoji { font-size: 48rpx; }
.inv-info { flex: 1; }
.inv-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}
.inv-price {
  font-size: 24rpx;
  color: #FF9800;
  margin-top: 4rpx;
}
.inv-count {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF9800;
  margin-right: 24rpx;
}
.inv-sell {
  background: #4CAF50;
  color: #fff;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
}

/* 出售弹窗 */
.sell-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}
.sell-modal {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  z-index: 1000;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.2);
}
.sell-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.sell-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.sell-modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}
.sell-modal-body {
  padding: 40rpx 40rpx 32rpx;
}
.sell-modal-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}
.sell-modal-label { color: #666; }
.sell-modal-value { font-weight: bold; color: #333; }
.sell-modal-input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 0;
}
.sell-modal-input {
  width: 200rpx;
  text-align: center;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
}
.sell-modal-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-top: 1rpx dashed #eee;
}
.sell-modal-total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF9800;
}
.sell-modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}
.sell-modal-cancel,
.sell-modal-confirm {
  flex: 1;
  border-radius: 0;
  border: none;
  padding: 28rpx 0;
  font-size: 30rpx;
}
.sell-modal-cancel {
  background: #f5f5f5;
  color: #666;
}
.sell-modal-confirm {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
  color: #fff;
}

/* 订单 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.order-timer { font-size: 26rpx; color: #999; }

.refresh-btn {
  background: #FF9800;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  border: none;
}
.refresh-btn::after { border: none; }
.refresh-btn[disabled] { background: #ddd; color: #999; }

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.order-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.order-card.completed {
  opacity: 0.5;
  background: #f5f5f5;
}
.order-info { flex: 1; }
.order-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}
.order-reward {
  font-size: 24rpx;
  display: flex;
  gap: 20rpx;
}
.reward-exp { color: #4CAF50; }
.reward-skill { color: #FF9800; font-weight: bold; }

.order-btn {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 36rpx;
  border-radius: 28rpx;
  border: none;
}
.order-btn::after { border: none; }
.order-btn[disabled] { background: #ddd; color: #999; }

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}